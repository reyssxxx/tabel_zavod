generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  role         String      @default("MANAGER") // ADMIN, MANAGER, ACCOUNTANT
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  users     User[]
}

model WorkSchedule {
  id          String     @id @default(cuid())
  name        String     @unique // "8-часовой", "Ночная смена (12ч)", "2/2 (12ч)", "Сутки/трое (24ч)"
  hoursPerDay Float
  employees   Employee[]
}

model Employee {
  id               String        @id @default(cuid())
  fullName         String
  position         String
  departmentId     String
  department       Department    @relation(fields: [departmentId], references: [id])
  personnelNumber  String        @unique
  isActive         Boolean       @default(true)
  scheduleId       String?
  schedule         WorkSchedule? @relation(fields: [scheduleId], references: [id])
  linkedEmployeeId String?
  linkedEmployee   Employee?     @relation("EmployeeLink", fields: [linkedEmployeeId], references: [id])
  linkedBy         Employee[]    @relation("EmployeeLink")
  timeRecords      TimeRecord[]
}

model MarkType {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  defaultHours Float
  color        String
  timeRecords  TimeRecord[]
}

model TimeRecord {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  date          DateTime
  markTypeId    String
  markType      MarkType @relation(fields: [markTypeId], references: [id])
  overtimeHours Float    @default(0)
  slot          Int      @default(0) // 0 = основная отметка, 1 = вторая (полдня)

  @@unique([employeeId, date, slot])
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique
  name        String
  isShortened Boolean  @default(false)
}
